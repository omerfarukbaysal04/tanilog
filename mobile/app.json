{
  "expo": {
    "name": "TanıLog",
    "slug": "tanilog-mobile",
    "scheme": "tanilog",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1722"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "TanıLog belge ve rapor fotoğraflarını yüklemek için galeri erişimi ister.",
          "cameraPermission": "TanıLog belge fotoğraflamak için kamera erişimi ister."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "TanıLog sesli sağlık kaydı oluşturmak için mikrofon erişimi ister."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0fb8a5"
        }
      ],
      "expo-sharing"
    ],
    "ios": {
      "supportsTablet": true,
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b1722"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.baysalsoft.tanilogmobile",
      "googleServicesFile": "./android/app/google-services.json",
      "runtimeVersion": "1.0.0"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "03375845-8b34-4ec3-a99f-4030f49f5481"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/03375845-8b34-4ec3-a99f-4030f49f5481"
    }
  }
}
