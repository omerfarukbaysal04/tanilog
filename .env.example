# TanıLog - Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayıp değerleri güncelleyin:
# cp .env.example .env

# PostgreSQL
POSTGRES_DB=tanilog
POSTGRES_USER=tanilog_user
POSTGRES_PASSWORD=your_secure_password_here

# Backend
TANILOG_DEBUG=true
SECRET_KEY=your_secure_secret_key_here_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
UPLOAD_DIR=uploads
PUBLIC_WEB_URL=http://localhost:3000
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tanilog.local

# Yapay Zeka
GEMINI_API_KEY=sizin_gemini_api_anahtariniz_buraya

# Frontend
VITE_API_URL=http://localhost:8000/api/v1
