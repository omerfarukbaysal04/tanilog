# TanıLog - Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayıp değerleri güncelleyin:
# cp .env.example .env

# PostgreSQL
POSTGRES_DB=tanilog
POSTGRES_USER=tanilog_user
POSTGRES_PASSWORD=your_secure_password_here

# Backend
TANILOG_DEBUG=true
SECRET_KEY=your_secure_secret_key_here_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Production example:
# ALLOWED_ORIGINS=["https://app.example.com"]
UPLOAD_DIR=uploads
PUBLIC_WEB_URL=http://localhost:3000
# Production example:
# PUBLIC_WEB_URL=https://app.example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tanilog.local

# Yapay Zeka
GEMINI_API_KEY=sizin_gemini_api_anahtariniz_buraya

# Frontend
VITE_API_URL=https://tanilog.onrender.com/api/v1
# Production example:
# VITE_API_URL=https://api.example.com/api/v1

# Mobile
EXPO_PUBLIC_API_URL=https://tanilog.onrender.com/api/v1

#Neon
DATABASE_URL="postgresql://neondb_owner:YOUR_NEON_DB_PASSWORD@ep-winter-sea-al3y5ngc-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
